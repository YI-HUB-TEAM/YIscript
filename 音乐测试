  play = function(self, initial_bpm)
    local bpm = initial_bpm or 120
    local ticks_per_beat = self.ticks_per_beat
    -- 合并所有轨道事件
    local all_events = {}
    for _, track in ipairs(self.tracks) do
      for _, ev in ipairs(track.events) do
        table.insert(all_events, ev)
      end
    end
    table.sort(all_events, function(a,b) return a.time < b.time end)
    -- 配对 on/off
    local note_on = {}
    local play_list = {}
    for _, ev in ipairs(all_events) do
      if ev.type == "on" then
        note_on[ev.note] = ev.time
      elseif ev.type == "off" then
        local on_time = note_on[ev.note]
        if on_time then
          local dur = ev.time - on_time
          table.insert(play_list, {time = on_time, note = ev.note, duration = dur})
          note_on[ev.note] = nil
        end
      elseif ev.type == "tempo" then
        table.insert(play_list, {time = ev.time, tempo = ev.bpm})
      end
    end
    table.sort(play_list, function(a,b) return a.time < b.time end)
    -- 反向映射 MIDI 编号 → 键盘字符
    if not _G.midiKeyMappings then
      error("Global midiKeyMappings not found")
    end
    local noteToKey = {}
    for k, v in pairs(_G.midiKeyMappings) do
      noteToKey[v] = k
    end
    local current_time = 0
    for _, item in ipairs(play_list) do
      if _G.STOPIT then break end
      if item.tempo then
        bpm = item.tempo
      else
        local delta_ticks = item.time - current_time
        if delta_ticks > 0 then
          local delta_beats = delta_ticks / ticks_per_beat
          resttrigger(delta_beats, bpm)
        end
        local dur_beats = item.duration / ticks_per_beat
        local key = noteToKey[item.note]
        if key then
          keypresstrigger(key, dur_beats, bpm, false)
        else
          warn("No key for note " .. item.note)
        end
        current_time = item.time
      end
    end
  end
}
